{
  "manifest_version": 3,
  "name": "PK Sticky Notes",
  "version": "1.0",
  "description": "Add sticky notes to web pages",
  "permissions": ["storage", "activeTab", "tabs"],
  "action": {
    "default_title": "Create New Note",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}