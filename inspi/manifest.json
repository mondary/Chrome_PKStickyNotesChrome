{
  "manifest_version": 3,
  "name": "PKsticky",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_title": "Click me"
  },
  "version": "1.1.0",
  "description": "Place sticky notes on webpages",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_globs": ["*.pdf"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "128": "assets/logo-48x48.png"
  }
}
