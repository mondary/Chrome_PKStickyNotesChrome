{
  "manifest_version": 3,
  "name": "PK Sticky Notes",
  "version": "1.0.3",
  "description": "Add sticky notes anywhere on web pages. Made by PK-Labs.",
  "short_name": "PK-Labs Notes",
  "permissions": ["storage", "activeTab", "contextMenus"],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_title": "Create New Note",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
